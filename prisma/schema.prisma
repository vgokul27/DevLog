// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hashed with bcrypt
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  entries   Entry[]
  projects  Project[]
  resources Resource[]

  @@index([email])
}

model Entry {
  id        String   @id @default(cuid())
  title     String
  body      String   // Markdown content
  date      DateTime @default(now())
  tags      String   // JSON string array
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  resources EntryResource[]

  @@index([date])
  @@index([projectId])
  @@index([userId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String
  techStack   String   // JSON string array
  status      String   // "Idea" | "Building" | "Shipped" | "Paused"
  liveUrl     String?
  repoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  entries   Entry[]
  resources ProjectResource[]

  @@index([status])
  @@index([userId])
}

model Resource {
  id         String   @id @default(cuid())
  title      String
  url        String
  category   String   // "Article" | "Video" | "Docs" | "Course" | "Other"
  notes      String?
  isFavorite Boolean  @default(false)
  isRead     Boolean  @default(false)
  tags       String   // JSON string array
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  entries  EntryResource[]
  projects ProjectResource[]

  @@index([category])
  @@index([isFavorite])
  @@index([isRead])
  @@index([userId])
}

// Join tables for many-to-many relationships
model EntryResource {
  id         String   @id @default(cuid())
  entryId    String
  resourceId String
  createdAt  DateTime @default(now())

  entry    Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([entryId, resourceId])
  @@index([entryId])
  @@index([resourceId])
}

model ProjectResource {
  id         String   @id @default(cuid())
  projectId  String
  resourceId String
  createdAt  DateTime @default(now())

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([projectId, resourceId])
  @@index([projectId])
  @@index([resourceId])
}
